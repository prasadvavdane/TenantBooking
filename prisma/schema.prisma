generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  TENANT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  UNAVAILABLE
  PENDING_APPROVAL
  REJECTED
}

enum PropertyType {
  FLAT
  APARTMENT
  VILLA
  PG
  COMMERCIAL_OFFICE
  SHOP
}

enum FurnishedType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum BHKType {
  RK
  ONE_BHK
  TWO_BHK
  THREE_BHK
  FOUR_PLUS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  emailVerifiedAt  DateTime?
  phone            String?   @unique
  phoneVerifiedAt  DateTime?
  passwordHash     String?
  image            String?
  role             UserRole  @default(TENANT)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  ownedProperties  Property[] @relation("OwnerProperties")
  bookings         Booking[] @relation("TenantBookings")
  sentMessages     Message[] @relation("SenderMessages")
  reviews          Review[]
  wishlist         Wishlist[]
  notifications    Notification[]
  adminLogs        AdminLog[]

  @@index([role])
}

model Profile {
  id                String             @id @default(cuid())
  userId            String             @unique
  kycStatus         VerificationStatus @default(PENDING)
  aadhaarNumber     String?
  panNumber         String?
  city              String?
  bio               String?
  recentlyViewed    String[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                   String          @id @default(cuid())
  ownerId              String
  title                String
  description          String
  propertyType         PropertyType
  furnishedType        FurnishedType
  bhkType              BHKType
  rent                 Int
  deposit              Int
  maintenanceCharges   Int             @default(0)
  preferredTenantType  String?
  availableFrom        DateTime
  parkingDetails       String?
  societyName          String?
  floorDetails         String?
  areaSqft             Int?
  balconyCount         Int             @default(0)
  bathroomCount        Int             @default(1)
  petsAllowed          Boolean         @default(false)
  brokerageInfo        String?
  leaseDurationMonths  Int?
  city                 String
  area                 String
  pincode              String
  addressLine          String?
  latitude             Float?
  longitude            Float?
  virtualTourUrl       String?
  videoUrl             String?
  documents            String[]
  isVerified           Boolean         @default(false)
  isOwnerListed        Boolean         @default(true)
  status               PropertyStatus  @default(PENDING_APPROVAL)
  aiRentSuggestion     Int?
  fraudRiskScore       Float?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  owner                User            @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  images               PropertyImage[]
  propertyAmenities    PropertyAmenity[]
  bookings             Booking[]
  reviews              Review[]
  wishlistedBy         Wishlist[]

  @@index([city, area, pincode])
  @@index([rent, bhkType, furnishedType])
  @@index([status, availableFrom])
  @@index([latitude, longitude])
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Amenity {
  id          String            @id @default(cuid())
  name        String            @unique
  icon        String?
  properties  PropertyAmenity[]
}

model PropertyAmenity {
  propertyId  String
  amenityId   String

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity     Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
}

model Booking {
  id          String        @id @default(cuid())
  propertyId  String
  tenantId    String
  slotStart   DateTime
  slotEnd     DateTime
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      User          @relation("TenantBookings", fields: [tenantId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@index([propertyId, slotStart, slotEnd])
  @@index([tenantId, status])
}

model Payment {
  id                String          @id @default(cuid())
  bookingId         String
  amount            Int
  currency          String          @default("INR")
  provider          PaymentProvider
  providerPaymentId String?
  invoiceUrl        String?
  status            PaymentStatus   @default(PENDING)
  createdAt         DateTime        @default(now())

  booking           Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model Chat {
  id          String    @id @default(cuid())
  propertyId  String?
  createdAt   DateTime  @default(now())

  messages    Message[]
}

model Message {
  id          String    @id @default(cuid())
  chatId      String
  senderId    String
  content     String
  attachment  String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  chat        Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User      @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model Review {
  id          String   @id @default(cuid())
  propertyId  String
  userId      String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId, rating])
}

model Wishlist {
  userId      String
  propertyId  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     NotificationChannel
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
}
